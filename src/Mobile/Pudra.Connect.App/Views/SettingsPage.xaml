<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:Pudra.Connect.App.Helpers"
             x:Class="Pudra.Connect.App.Views.SettingsPage"
             BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"

             Shell.NavBarIsVisible="False">
    
   <ScrollView>
         <VerticalStackLayout Spacing="20" Padding="15">
             
             <Label Text="Hesap" FontSize="Micro" Style="{StaticResource Headline}" Margin="5,0"/>
             <Border Style="{StaticResource CardView}">
                 <VerticalStackLayout Spacing="0">
                     <Grid Padding="15,10" ColumnDefinitions="Auto,*">
                         <Label Grid.Column="0" Text="Kullanıcı Adı" />
                         <Label Grid.Column="1" Text="{Binding UserName}" HorizontalOptions="End" TextColor="Gray"/>
                     </Grid>
                     <BoxView Style="{StaticResource Separator}"/>
                     <Grid Padding="15,10" ColumnDefinitions="Auto,*">
                         <Label Grid.Column="0" Text="Rol" />
                         <Label Grid.Column="1" Text="{Binding UserRole}" HorizontalOptions="End" TextColor="Gray"/>
                     </Grid>
                      <BoxView Style="{StaticResource Separator}"/>
                      <Grid Padding="15,10">
                          <Grid.GestureRecognizers>
                              <TapGestureRecognizer Command="{Binding GoToMyProfileCommand}"/>
                          </Grid.GestureRecognizers>
                          <Label Text="Profili Düzenle"/>
                          <Label Text="{x:Static helpers:IconFont.ChevronRight}" FontFamily="MaterialSymbols" HorizontalOptions="End" TextColor="Gray"/>
                      </Grid>
                 </VerticalStackLayout>
             </Border>
 
             <Label Text="Yönetim" FontSize="Micro" Style="{StaticResource Headline}" Margin="5,0"/>
             <Border Style="{StaticResource CardView}">
                 <VerticalStackLayout>
                     
                     <Grid Padding="15,10" IsVisible="{Binding IsAdmin}">
                         <Grid.GestureRecognizers>
                             <TapGestureRecognizer Command="{Binding GoToUserManagementCommand}"/>
                         </Grid.GestureRecognizers>
                         <Label Text="Kullanıcı Yönetimi" />
                         <Label Text="{x:Static helpers:IconFont.ChevronRight}" FontFamily="MaterialSymbols" HorizontalOptions="End" TextColor="Gray"/>
                     </Grid>
                  
                     
                 </VerticalStackLayout>
               
                 
             </Border>
             <Border Style="{StaticResource CardView}">
                 <Grid Padding="15,10">
                     <Grid.GestureRecognizers>
                         <TapGestureRecognizer Command="{Binding LogoutCommand}"/>
                     </Grid.GestureRecognizers>
                     <Label Text="Çıkış Yap" />
                     <Label Text="{x:Static helpers:IconFont.Logout}" FontFamily="MaterialSymbols" HorizontalOptions="End" TextColor="Gray"/>
                 </Grid>
             </Border>
             
 
         </VerticalStackLayout>
     </ScrollView>
</ContentPage>