<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pudra.Connect.App.Views.UserDetailPage"
             BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"

             Title="{Binding PageTitle}">
    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20">
            <Label Text="Kullanıcı Bilgileri" FontSize="Large" FontAttributes="Bold"/>
            
            <Entry Placeholder="Kullanıcı Adı" Text="{Binding Username}" />
            <Entry Placeholder="Tam Ad" Text="{Binding FullName}" />
            <Entry Placeholder="Şifre" Keyboard="Numeric" Text="{Binding Password}" IsPassword="True" />

           
            <Label Text="Kullanıcı Rolü" Margin="0,10,0,0"/>
            <Picker ItemsSource="{Binding Roles}" 
                    SelectedItem="{Binding SelectedRole}" />

            <Button Text="Kaydet" 
                    Command="{Binding SaveCommand}" 
                    IsEnabled="{Binding IsNotBusy}"
                    HorizontalOptions="Fill"
                    Margin="0,20,0,0"/>
            
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>